{
  "info": {
    "name": "Medical Insurance MVP Backend",
    "_postman_id": "6b0ce1a7-6d4b-4d7d-9c1d-2a1b8b7c1001",
    "description": "Postman collection for signup, login, MFA, profile, prediction, forecast, admin dashboard, and training export.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "challengeId", "value": "" },
    { "key": "otpCode", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Signup User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"UserPass123!\",\n  \"tenant_name\": \"Pacific Care\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/signup"
      }
    },
    {
      "name": "Auth - Login Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('challengeId', json.challenge_id || '');",
              "pm.collectionVariables.set('otpCode', json.otp_code_preview || '');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"ChangeMe123!\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/login"
      }
    },
    {
      "name": "Auth - MFA Verify",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('accessToken', json.access_token || '');",
              "pm.collectionVariables.set('refreshToken', json.refresh_token || '');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"challenge_id\": \"{{challengeId}}\",\n  \"otp\": \"{{otpCode}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/mfa/verify"
      }
    },
    {
      "name": "Auth - Refresh",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/refresh"
      }
    },
    {
      "name": "Me - Get Current User",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{accessToken}}", "type": "string" }
          ]
        },
        "url": "{{baseUrl}}/api/v1/me"
      }
    },
    {
      "name": "Me - Complete Onboarding",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{accessToken}}", "type": "string" }
          ]
        },
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"consent_version\": \"2026-03\",\n  \"consent_accepted\": true,\n  \"platform_purpose_seen\": true,\n  \"data_use_summary_seen\": true\n}"
        },
        "url": "{{baseUrl}}/api/v1/me/onboarding"
      }
    },
    {
      "name": "Me - Save Profile",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{accessToken}}", "type": "string" }
          ]
        },
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"age\": 42,\n  \"bmi\": 27.6,\n  \"smoker_status\": false,\n  \"dependents\": 2,\n  \"region\": \"Ontario\",\n  \"sex\": \"Female\",\n  \"recent_hospitalizations\": 1,\n  \"base_risk_score\": 18.0,\n  \"subscription_tier\": \"Premium\",\n  \"tenant_company\": \"Pacific Care\",\n  \"consent_to_model_improvement\": true\n}"
        },
        "url": "{{baseUrl}}/api/v1/me/profile"
      }
    },
    {
      "name": "Predict - Run Prediction",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{accessToken}}", "type": "string" }
          ]
        },
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"profile\": {\n    \"age\": 42,\n    \"bmi\": 27.6,\n    \"smoker_status\": false,\n    \"dependents\": 2,\n    \"region\": \"Ontario\",\n    \"sex\": \"Female\",\n    \"recent_hospitalizations\": 1,\n    \"base_risk_score\": 18.0,\n    \"subscription_tier\": \"Premium\",\n    \"tenant_company\": \"Pacific Care\",\n    \"consent_to_model_improvement\": true\n  },\n  \"persist_profile\": true\n}"
        },
        "url": "{{baseUrl}}/api/v1/predict"
      }
    },
    {
      "name": "Predict - What If",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{accessToken}}", "type": "string" }
          ]
        },
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"overrides\": {\n    \"smoker_status\": true,\n    \"bmi\": 31.2\n  }\n}"
        },
        "url": "{{baseUrl}}/api/v1/predict/what-if"
      }
    },
    {
      "name": "Forecast - Run Forecast",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{accessToken}}", "type": "string" }
          ]
        },
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"profile\": {\n    \"age\": 42,\n    \"bmi\": 27.6,\n    \"smoker_status\": false,\n    \"dependents\": 2,\n    \"region\": \"Ontario\",\n    \"sex\": \"Female\",\n    \"recent_hospitalizations\": 1,\n    \"base_risk_score\": 18.0,\n    \"subscription_tier\": \"Premium\",\n    \"tenant_company\": \"Pacific Care\",\n    \"consent_to_model_improvement\": true\n  },\n  \"persist_profile\": false\n}"
        },
        "url": "{{baseUrl}}/api/v1/forecast"
      }
    },
    {
      "name": "Plans - Coming Soon",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{accessToken}}", "type": "string" }
          ]
        },
        "url": "{{baseUrl}}/api/v1/plans/recommend"
      }
    },
    {
      "name": "Admin - Dashboard",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{accessToken}}", "type": "string" }
          ]
        },
        "url": "{{baseUrl}}/api/v1/admin/dashboard"
      }
    },
    {
      "name": "Admin - Metrics",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{accessToken}}", "type": "string" }
          ]
        },
        "url": "{{baseUrl}}/api/v1/admin/metrics"
      }
    },
    {
      "name": "Admin - Funnel",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{accessToken}}", "type": "string" }
          ]
        },
        "url": "{{baseUrl}}/api/v1/admin/funnel"
      }
    },
    {
      "name": "Admin - Training Export",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{accessToken}}", "type": "string" }
          ]
        },
        "url": "{{baseUrl}}/api/v1/admin/training-data/export"
      }
    }
  ]
}
